        "import pandas as pd\n",
        "df = pd.read_csv('netflix_data.csv')\n",
        "renewal_pct = (df['SubscriptionRenewed'] == 'Yes').mean() * 100\n",
        "print(f\"Subscription Renewal Rate: {renewal_pct:.2f}%\")"
